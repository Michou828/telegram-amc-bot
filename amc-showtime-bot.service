[Unit]
Description=AMC Showtime Telegram Bot
After=network.target

[Service]
WorkingDirectory=/home/michou/telegram-amc-bot
ExecStart=/home/michou/telegram-amc-bot/.venv/bin/python amc_showtime_bot.py
Restart=always
RestartSec=10
StandardOutput=inherit
StandardError=inherit

[Install]
WantedBy=multi-user.target
